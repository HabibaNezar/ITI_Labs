@model IEnumerable<Student>

@{
    ViewData["Title"] = "Student List";
}

<div class="text-center">
    <h1 class="display-4">All Students</h1>
</div>

<table class="table table-bordered table-hover mt-4">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>SSN</th>
            <th>Email</th>
            <th>Address</th>
            <th>Phone</th>
            <th>Image</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.SSN</td>
                <td>@item.Email</td>
                <td>@item.Address</td>
                <td>@item.Phone</td>
                <td>
                    <img src="/images/@item.Image" width="50" height="50" style="border-radius:50%" />
                </td>
                <td>
                    <a href="/Student/GetByID/@item.Id" class="btn btn-info btn-sm">Show Card</a>
                </td>
            </tr>
        }
    </tbody>
</table>