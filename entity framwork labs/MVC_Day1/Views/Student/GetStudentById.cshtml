@model Student

@{
    ViewData["Title"] = "Student Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0" style="border-radius: 15px; overflow: hidden;">

                <img src="/images/@Model.Image" class="card-img-top" alt="@Model.Name" style="height: 320px; object-fit: cover;">

                <div class="card-body">
                    <h4 class="card-title fw-bold text-center mb-3">@Model.Name</h4>

                    <ul class="list-group list-group-flush">
                        <li class="list-group-item"><strong>🆔 SSN:</strong> @Model.SSN</li>
                        <li class="list-group-item"><strong>📧 Email:</strong> @Model.Email</li>
                        <li class="list-group-item"><strong>📞 Phone:</strong> @Model.Phone</li>
                        <li class="list-group-item"><strong>📍 Address:</strong> @Model.Address</li>
                    </ul>

                    <div class="d-grid gap-2 mt-4">
                        <a href="/Student/Index" class="btn btn-secondary shadow-sm">Back to Student List</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>