<style>
    .main-navbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 48px;
        height: 64px;
        background: var(--purple);
        box-shadow: 0 2px 12px rgba(45,36,56,.18);
    }

        .main-navbar .nav-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.35rem;
            letter-spacing: .12em;
            color: var(--white);
            text-decoration: none;
        }

        .main-navbar .brand-dot {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--orange);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .85rem;
            font-weight: 700;
            color: var(--purple);
            box-shadow: 0 0 0 3px rgba(245,166,35,.25);
        }

        .main-navbar .nav-links {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .main-navbar .nav-link {
            padding: 8px 16px;
            border-radius: 8px;
            font-size: .85rem;
            font-weight: 500;
            color: rgba(232,217,181,.7);
            text-decoration: none;
            transition: .2s;
        }

            .main-navbar .nav-link:hover {
                background: rgba(255,255,255,.07);
                color: var(--white);
            }

        .main-navbar .nav-divider {
            width: 1px;
            height: 22px;
            background: rgba(255,255,255,.1);
            margin: 0 4px;
        }

        .main-navbar .btn-register {
            padding: 8px 20px;
            border-radius: 8px;
            font-size: .85rem;
            font-weight: 600;
            color: var(--orange);
            background: transparent;
            text-decoration: none;
            border: 1.5px solid rgba(245,166,35,.5);
            transition: .2s;
        }

            .main-navbar .btn-register:hover {
                border-color: var(--orange);
                background: rgba(245,166,35,.08);
                color: var(--white);
            }

        .main-navbar .btn-login {
            padding: 8px 20px;
            border-radius: 8px;
            font-size: .85rem;
            font-weight: 600;
            color: var(--purple);
            background: var(--orange);
            text-decoration: none;
            transition: .2s;
            border: none;
        }

            .main-navbar .btn-login:hover {
                background: var(--orange-dark);
            }

    @@media (max-width: 768px) {
        .main-navbar {
            padding: 0 20px;
        }

            .main-navbar .nav-link {
                display: none;
            }
    }
</style>

<nav class="main-navbar">
    <a asp-controller="Home" asp-action="Index" class="nav-brand">
        <div class="brand-dot">
            <div class="brand-avatar">
                <i class="fa-solid fa-graduation-cap"></i>
            </div>
        </div>
        EDU<span style="color:var(--orange)">TRACK</span>
    </a>
    <div class="nav-links">
        @* <a asp-controller="Home" asp-action="Index" class="nav-link">Home</a>
        <a asp-controller="Student" asp-action="Index" class="nav-link">Students</a>
        <a asp-controller="Instructor" asp-action="Index" class="nav-link">Instructors</a>
        *@
        <div class="nav-divider"></div>
        <a asp-controller="Account" asp-action="RegisterForm" class="btn-register">Register</a>
        <a asp-controller="Account" asp-action="LoginForm" class="btn-login">Login</a>
    </div>
</nav>