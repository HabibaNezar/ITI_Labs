@model Department

@{
    ViewData["Title"] = "GetDepartmentDetails";
}

<style>
    .details-page {
        max-width: 520px;
        margin: 0 auto;
        padding: 0 16px;
        height: 100%;
        display: flex;
        align-items: center;
    }

    .detail-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 6px 32px rgba(45,36,56,.12);
        overflow: hidden;
        border: 1px solid rgba(45,36,56,.06);
        width: 100%;
    }

    /* Header */
    .detail-card-header {
        background: #2D2438;
        padding: 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        text-align: center;
    }

    .detail-icon {
        width: 56px;
        height: 56px;
        background: #F5A623;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #2D2438;
        font-size: 1.4rem;
    }

    .detail-card-header h4 {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.6rem;
        letter-spacing: .08em;
        color: #fff;
        margin: 0;
        line-height: 1;
    }

    .detail-card-header span {
        font-size: .75rem;
        color: rgba(232,217,181,.55);
        letter-spacing: .05em;
    }

    /* Body */
    .detail-card-body {
        padding: 22px 24px;
    }

    .detail-row {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 14px 0;
        border-bottom: 1px solid #F0EBE0;
    }

        .detail-row:last-child {
            border-bottom: none;
        }

    .detail-row-icon {
        width: 34px;
        height: 34px;
        background: rgba(245,166,35,.12);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #F5A623;
        font-size: .85rem;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .detail-row-content label {
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: #7A7090;
        display: block;
        margin-bottom: 2px;
    }

    .detail-row-content span {
        font-size: .92rem;
        color: #1A1525;
        font-weight: 500;
    }

    /* Footer */
    .detail-footer {
        padding: 16px 24px;
        border-top: 1px solid #F0EBE0;
        display: flex;
        justify-content: space-between;
        gap: 10px;
    }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: transparent;
        color: #574E6E;
        font-size: .83rem;
        font-weight: 600;
        padding: 10px 20px;
        border: 1.5px solid #E8D9B5;
        border-radius: 10px;
        text-decoration: none;
        transition: border-color .2s, color .2s, background .2s;
    }

        .btn-back:hover {
            border-color: #2D2438;
            color: #2D2438;
            background: #F0EBE0;
        }

    .btn-edit {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: #F5A623;
        color: #2D2438;
        font-weight: 700;
        font-size: .83rem;
        padding: 10px 20px;
        border-radius: 10px;
        text-decoration: none;
        border: none;
        transition: background .2s, transform .15s, box-shadow .2s;
        box-shadow: 0 4px 14px rgba(245,166,35,.3);
    }

        .btn-edit:hover {
            background: #D4891A;
            color: #2D2438;
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(245,166,35,.4);
        }
</style>

<div class="details-page">
    <div class="detail-card">

        <!-- Header -->
        <div class="detail-card-header">
            <div class="detail-icon">
                <i class="fa-solid fa-book"></i>
            </div>
            <h4>@Model.DeptName</h4>
            <span>Department Details</span>
        </div>

        <!-- Detail rows -->
        <div class="detail-card-body">

            <div class="detail-row">
                <div class="detail-row-icon"><i class="fa-solid fa-hashtag"></i></div>
                <div class="detail-row-content">
                    <label>Department ID</label>
                    <span>@Model.DeptId</span>
                </div>
            </div>

            <div class="detail-row">
                <div class="detail-row-icon"><i class="fa-solid fa-graduation-cap"></i></div>
                <div class="detail-row-content">
                    <label>Department Name</label>
                    <span>@Model.DeptName</span>
                </div>
            </div>

            <div class="detail-row">
                <div class="detail-row-icon"><i class="fa-solid fa-align-left"></i></div>
                <div class="detail-row-content">
                    <label>Department phone</label>
                    <span>@Model.Phone</span>
                </div>
            </div>

            <div class="detail-row">
                <div class="detail-row-icon"><i class="fa-solid fa-align-left"></i></div>
                <div class="detail-row-content">
                    <label>Department Location</label>
                    <span>@Model.Loc</span>
                </div>
            </div>

        </div>

        <!-- Footer -->
        <div class="detail-footer">
            <a href="/Department/GetAllDepartments" class="btn-back">
                <i class="fa-solid fa-arrow-left"></i>
                Back to Departments
            </a>
            <a href="/Department/EditDepartmentForm/@Model.DeptId" class="btn-edit">
                <i class="fa-solid fa-pen"></i>
                Edit Course
            </a>
        </div>

    </div>
</div>

