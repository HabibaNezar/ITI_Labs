@{
    ViewData["Title"] = "Home";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EduTrack — Home</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --orange: #F5A623;
            --orange-dark: #D4891A;
            --purple: #2D2438;
            --purple-mid: #3D3250;
            --purple-light: #574E6E;
            --beige: #E8D9B5;
            --white: #FFFFFF;
            --bg: #F0EBE0;
            --text-main: #1A1525;
            --text-muted: #7A7090;
        }

        html, body {
            height: 100%;
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text-main);
            overflow-x: hidden;
        }

        .hero {
            display: grid;
            grid-template-columns: 1fr 1fr;
            align-items: center;
            min-height: calc(100vh - 64px);
            overflow: hidden;
        }

        .hero-left {
            padding: 80px 60px 80px 72px;
        }

        .hero-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(245,166,35,.12);
            border: 1px solid rgba(245,166,35,.3);
            border-radius: 20px;
            padding: 5px 14px;
            font-size: .75rem;
            font-weight: 600;
            letter-spacing: .09em;
            color: var(--orange-dark);
            text-transform: uppercase;
            margin-bottom: 28px;
        }

        .hero-tag-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--orange);
        }

        .hero-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: clamp(2rem, 5vw, 3rem);
            line-height: 1.05;
            letter-spacing: .04em;
            color: var(--purple);
            margin-bottom: 20px;
        }

            .hero-title span {
                color: var(--orange);
            }

        .hero-desc {
            font-size: 1rem;
            line-height: 1.7;
            color: var(--text-muted);
            max-width: 460px;
            margin-bottom: 40px;
        }

        .hero-actions {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
        }

        .cta-secondary {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            padding: 14px 28px;
            border-radius: 10px;
            background: var(--orange);
            color: var(--purple);
            font-size: .9rem;
            font-weight: 700;
            text-decoration: none;
            transition: .2s;
        }

            .cta-secondary:hover {
                background: var(--orange-dark);
                transform: translateY(-1px);
            }

        .cta-primary {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            padding: 14px 28px;
            border-radius: 10px;
            background: var(--purple);
            color: var(--white);
            font-size: .9rem;
            font-weight: 600;
            text-decoration: none;
            transition: .2s;
        }

            .cta-primary:hover {
                background: var(--purple-mid);
                transform: translateY(-1px);
            }

        .hero-right {
            background: var(--purple);
            min-height: calc(100vh - 64px);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .blob {
            position: absolute;
            border-radius: 50%;
            opacity: .15;
            filter: blur(50px);
        }

        .blob-1 {
            width: 320px;
            height: 320px;
            background: var(--orange);
            top: -80px;
            right: -80px;
        }

        .blob-2 {
            width: 200px;
            height: 200px;
            background: var(--purple-light);
            bottom: 40px;
            left: -60px;
        }

        .floating-badge {
            position: absolute;
            top: 36px;
            left: 24px;
            z-index: 10;
            background: var(--orange);
            border-radius: 10px;
            padding: 10px 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 4px 16px rgba(245,166,35,.35);
        }

        .fb-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--purple);
            animation: pulse 1.5s infinite;
        }

        .fb-text {
            font-size: .78rem;
            font-weight: 700;
            color: var(--purple);
        }

        #three-canvas {
            width: 100% !important;
            height: 100% !important;
            position: absolute;
            top: 0;
            left: 0;
            z-index: 2;
            cursor: grab;
        }

        @@keyframes pulse {
            0% {
                opacity: 1;
            }

            50% {
                opacity: 0.5;
            }

            100% {
                opacity: 1;
            }
        }

        @@media (max-width: 900px) {
            .hero {
                grid-template-columns: 1fr;
            }

            .hero-right {
                height: 400px;
                min-height: 400px;
            }

            .hero-left {
                padding: 60px 32px;
                text-align: center;
            }

            .hero-desc {
                margin-left: auto;
                margin-right: auto;
            }

            .hero-actions {
                justify-content: center;
            }
        }
    </style>
</head>
<body>

    <partial name="_NavHomePV" />

    <section class="hero">
        <div class="hero-left">
            <div class="hero-tag">
                <div class="hero-tag-dot"></div>
                Academic Management System
            </div>
            <h3 class="hero-title">
                Welcome to<br>
                <span>Student, Instructor</span><br>
                &amp; Course Hub
            </h3>
            <p class="hero-desc">
                A centralized platform to manage students, instructors, and courses with ease.
            </p>
            <div class="hero-actions">
                <a asp-controller="Account" asp-action="RegisterForm" class="cta-secondary">Get Started &rarr;</a>
            </div>
        </div>

        <div class="hero-right">
            <div class="blob blob-1"></div>
            <div class="blob blob-2"></div>
            <div class="floating-badge">
                <div class="fb-dot"></div>
                <span class="fb-text">Live model active</span>
            </div>
            <canvas id="three-canvas"></canvas>
        </div>
    </section>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <script>
        const canvas = document.getElementById('three-canvas');
        const container = canvas.parentElement;

        const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(container.clientWidth, container.clientHeight);

        // ✅ No tone mapping — model keeps its exact original colors
        renderer.outputEncoding = THREE.sRGBEncoding;
        renderer.toneMapping = THREE.NoToneMapping;

        const scene = new THREE.Scene();

        const camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 1000);
        camera.position.set(0, 0, 10);

        // ✅ Pure white lights — no color cast on the model
        const ambient = new THREE.AmbientLight(0xffffff, 1.5);
        scene.add(ambient);

        const dirLight = new THREE.DirectionalLight(0xffffff, 0.6);
        dirLight.position.set(5, 10, 10);
        scene.add(dirLight);

        const controls = new THREE.OrbitControls(camera, canvas);
        controls.enablePan = false;
        controls.enableZoom = true;
        controls.target.set(0, 0, 0);
        controls.update();

        let model = null;
        let autoTime = 0;       // drives the idle swing
        let isHovered = false;
        let hoverTarget = 0;    // target rotation when hovered
        let currentRot = 0;     // actual smoothed rotation

        const loader = new THREE.GLTFLoader();
        loader.load('/models/img1.glb', (gltf) => {
            model = gltf.scene;

            // ✅ Keep every material exactly as authored — no emissive override, no color change
            model.traverse((child) => {
                if (child.isMesh) {
                    child.material = Array.isArray(child.material)
                        ? child.material.map(m => { m.needsUpdate = true; return m; })
                        : (child.material.needsUpdate = true, child.material);
                }
            });

            const box = new THREE.Box3().setFromObject(model);
            const center = box.getCenter(new THREE.Vector3());
            const size   = box.getSize(new THREE.Vector3());

            model.position.sub(center); // center the model at origin

            const maxDim = Math.max(size.x, size.y, size.z);
            model.scale.setScalar(6 / maxDim);

            scene.add(model);

            if (gltf.animations?.length) {
                window._mixer = new THREE.AnimationMixer(model);
                window._mixer.clipAction(gltf.animations[0]).play();
            }
        });

        // ✅ Hover: rotate toward the side the mouse is on
        container.addEventListener('mousemove', (e) => {
            isHovered = true;
            const rect = container.getBoundingClientRect();
            const x = (e.clientX - rect.left) / rect.width; // 0 = left, 1 = right
            // left side → negative (rotate left), right side → positive (rotate right)
            hoverTarget = (x - 0.5) * 1.4;
        });

        container.addEventListener('mouseleave', () => {
            isHovered = false;
            hoverTarget = 0;
        });

        window.addEventListener('resize', () => {
            const w = container.clientWidth;
            const h = container.clientHeight;
            renderer.setSize(w, h);
            camera.aspect = w / h;
            camera.updateProjectionMatrix();
        });

        const clock = new THREE.Clock();

        function animate() {
            requestAnimationFrame(animate);
            const delta = clock.getDelta();
            autoTime += delta;

            if (window._mixer) window._mixer.update(delta);

            if (model) {
                let target;

                if (isHovered) {
                    // Hover → snap to mouse-driven rotation
                    target = hoverTarget;
                } else {
                    // Idle → smooth left-right swing (sine wave on Y rotation)
                    target = Math.sin(autoTime * 0.9) * 0.55;
                }

                // Smooth interpolation toward target
                currentRot += (target - currentRot) * 0.05;
                model.rotation.y = currentRot;
            }

            controls.update();
            renderer.render(scene, camera);
        }

        animate();
    </script>
</body>
</html>