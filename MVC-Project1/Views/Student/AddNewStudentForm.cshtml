@using MVC_Project1.ViewModels
@model StudentViewModel
@{
    ViewData["Title"] = "Add New Student";
}

<style>
    /* ── Page wrapper (Updated for Perfect Centering) ── */
    .form-page {
        width: 100%;
        min-height: calc(100vh - 120px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    /* ── Card ── */
    .student-card {
        width: 100%;
        max-width: 800px;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 6px 32px rgba(45, 36, 56, .12);
        overflow: hidden;
        border: 1px solid rgba(45, 36, 56, .06);
    }

    /* ── Card header ── */
    .student-card-header {
        background: #2D2438;
        padding: 14px 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .student-card-header .header-icon {
            width: 40px;
            height: 40px;
            background: #F5A623;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #2D2438;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .student-card-header h4 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.4rem;
            letter-spacing: .08em;
            color: #fff;
            margin: 0;
            line-height: 1;
        }

        .student-card-header span {
            font-size: .75rem;
            color: rgba(232,217,181,.6);
            letter-spacing: .04em;
        }

    /* ── Card body ── */
    .student-card-body {
        padding: 18px 24px;
    }

    /* ── Form labels ── */
    .form-label {
        font-size: .8rem;
        font-weight: 600;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: #574E6E;
        margin-bottom: 4px;
    }

    /* ── Inputs, selects ── */
    .form-control,
    .form-select {
        border: 1.5px solid #E8D9B5;
        border-radius: 10px;
        padding: 8px 12px;
        font-size: .85rem;
        color: #1A1525;
        background: #F9F6F0;
        transition: border-color .2s, box-shadow .2s, background .2s;
        box-shadow: none;
    }

        .form-control::placeholder {
            color: #b0a5c0;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: #F5A623;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(245,166,35,.15);
            outline: none;
        }

        /* File input */
        .form-control[type="file"] {
            padding: 8px 12px;
            cursor: pointer;
        }

            .form-control[type="file"]::-webkit-file-upload-button {
                background: #2D2438;
                color: #F5A623;
                border: none;
                border-radius: 7px;
                padding: 6px 14px;
                font-size: .78rem;
                font-weight: 600;
                letter-spacing: .04em;
                cursor: pointer;
                margin-right: 12px;
                transition: background .2s;
            }

                .form-control[type="file"]::-webkit-file-upload-button:hover {
                    background: #3D3250;
                }

    .file-hint {
        font-size: .74rem;
        color: #7A7090;
        margin-top: 5px;
        display: block;
    }

    /* ── Section divider label ── */
    .field-group {
        position: relative;
        margin-bottom: 12px;
    }

    /* ── Submit / Back buttons ── */
    .form-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-top: 1px solid #F0EBE0;
        padding-top: 14px;
        margin-top: 4px;
        gap: 12px;
    }

    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #F5A623;
        color: #2D2438;
        font-weight: 700;
        font-size: .85rem;
        letter-spacing: .04em;
        padding: 11px 26px;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        transition: background .2s, transform .15s, box-shadow .2s;
        box-shadow: 0 4px 14px rgba(245,166,35,.35);
    }

        .btn-save:hover {
            background: #D4891A;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(245,166,35,.45);
        }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: transparent;
        color: #574E6E;
        font-size: .83rem;
        font-weight: 600;
        padding: 10px 20px;
        border: 1.5px solid #E8D9B5;
        border-radius: 10px;
        text-decoration: none;
        transition: border-color .2s, color .2s, background .2s;
    }

        .btn-back:hover {
            border-color: #2D2438;
            color: #2D2438;
            background: #F0EBE0;
        }

    /* ── Validation text ── */
    .text-danger {
        font-size: .78rem;
        margin-top: 4px;
        display: block;
    }
</style>

<div class="form-page">
    <div class="student-card">

        <div class="student-card-header">
            <div class="header-icon">
                <i class="fa-solid fa-user-plus"></i>
            </div>
            <div>
                <h4>Add New Student</h4>
                <span>Fill in the details below to register a new student</span>
            </div>
        </div>

        <div class="student-card-body">

            
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div asp-validation-summary="All" class="text-danger"></div>
            <form asp-controller="Student" asp-action="SaveNewStudent" method="post" enctype="multipart/form-data">

                <partial name="_StudentFormDataPV"></partial>
                

            </form>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"></partial>
}