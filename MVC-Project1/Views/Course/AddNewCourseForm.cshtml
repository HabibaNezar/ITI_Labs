@model Course
@{
    ViewData["Title"] = "AddNewCourseForm";
}

<style>
    .form-page {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 16px;
        height: 100%;
        display: flex;
        align-items: center;
    }

    .student-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 6px 32px rgba(45,36,56,.12);
        overflow: hidden;
        border: 1px solid rgba(45,36,56,.06);
        width: 100%;
    }

    .student-card-header {
        background: #2D2438;
        padding: 14px 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .student-card-header .header-icon {
            width: 40px;
            height: 40px;
            background: #F5A623;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #2D2438;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .student-card-header h4 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.4rem;
            letter-spacing: .08em;
            color: #fff;
            margin: 0;
            line-height: 1;
        }

        .student-card-header span {
            font-size: .75rem;
            color: rgba(232,217,181,.6);
            letter-spacing: .04em;
        }

    .student-card-body {
        padding: 18px 24px;
    }

    .form-label {
        font-size: .8rem;
        font-weight: 600;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: #574E6E;
        margin-bottom: 4px;
    }

    .form-control {
        border: 1.5px solid #E8D9B5;
        border-radius: 10px;
        padding: 8px 12px;
        font-size: .85rem;
        color: #1A1525;
        background: #F9F6F0;
        transition: border-color .2s, box-shadow .2s, background .2s;
        box-shadow: none;
    }

        .form-control::placeholder {
            color: #b0a5c0;
        }

        .form-control:focus {
            border-color: #F5A623;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(245,166,35,.15);
            outline: none;
        }

    .field-group {
        position: relative;
        margin-bottom: 12px;
    }

    .text-danger {
        font-size: .78rem;
        margin-top: 4px;
        display: block;
    }

    .form-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-top: 1px solid #F0EBE0;
        padding-top: 14px;
        margin-top: 4px;
        gap: 12px;
    }

    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #F5A623;
        color: #2D2438;
        font-weight: 700;
        font-size: .85rem;
        letter-spacing: .04em;
        padding: 11px 26px;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        transition: background .2s, transform .15s, box-shadow .2s;
        box-shadow: 0 4px 14px rgba(245,166,35,.35);
    }

        .btn-save:hover {
            background: #D4891A;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(245,166,35,.45);
        }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: transparent;
        color: #574E6E;
        font-size: .83rem;
        font-weight: 600;
        padding: 10px 20px;
        border: 1.5px solid #E8D9B5;
        border-radius: 10px;
        text-decoration: none;
        transition: border-color .2s, color .2s, background .2s;
    }

        .btn-back:hover {
            border-color: #2D2438;
            color: #2D2438;
            background: #F0EBE0;
        }
</style>

<div class="form-page">
    <div class="student-card">

        <!-- Header -->
        <div class="student-card-header">
            <div class="header-icon">
                <i class="fa-solid fa-book-medical"></i>
            </div>
            <div>
                <h4>Add New Course</h4>
                <span>Fill in the details below to register a new course</span>
            </div>
        </div>

        <!-- Body -->
        <div class="student-card-body">
            <div class="text-danger mb-3"></div>

            <form method="post" asp-action="SaveAddNewCourse" enctype="multipart/form-data">
                <input type="hidden" asp-for="CrsId" value="0" />
                <!-- Course Name -->
                <div class="field-group">
                    <label class="form-label">Course Name</label>
                    <input asp-for="Name"  class="form-control" placeholder="Enter course name" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <!-- Course Description -->
                <div class="field-group">
                    <label class="form-label">Course Description</label>
                    <input asp-for="Description"  type="text" class="form-control" placeholder="Enter course description" required />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <!-- Course min degree -->
                <div class="field-group">
                    <label class="form-label">Course Min Degree</label>
                    <input asp-for="MinDegree" class="form-control" placeholder="Enter course min degree" required />
                    <span asp-validation-for="MinDegree" class="text-danger"></span>
                </div>

                <!-- Course min degree -->
                <div class="field-group">
                    <label class="form-label">Course Max Degree</label>
                    <input asp-for="MaxDegree" class="form-control" placeholder="Enter course max degree" required />
                    <span asp-validation-for="MaxDegree" class="text-danger"></span>
                </div>

                <!-- Footer -->
                <div class="form-footer">
                    <a href="/course/GetAllCourses" class="btn-back">
                        <i class="fa-solid fa-arrow-left"></i>
                        Back to All Courses
                    </a>
                    <input type="submit" value="Save Course Data" class="btn-save" />
                </div>

            </form>
        </div>

    </div>
</div>
@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}